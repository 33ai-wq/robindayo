    "ROBIDY_BASE_URL": "https://robidy.app",
    "RADAR_TTL_SECONDS": "60",
    "RADAR_FREE_EVENT_LIMIT": "5"
  },
  "triggers": [
    {
      "name": "radar-cron",
      "type": "cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
