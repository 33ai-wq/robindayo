{
  "name": "hood-sniper",
  "main": "src/index.js",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "vars": {
    "X402_PAYOUT_ADDRESS": "0x57EEC52d76A4A78D4562fc2564101A4bD2e3F357",
    "X402_BYPASS": "false",
    "ARCUS_BASE_URL": "https://api.arcus.xyz",
